@model List<Pokemon>

<h1>Pokemons Nuget</h1>

<form method="post">
    <label>Nombre del Pokemon</label>
    <input type="text" name="nombre" class="form-control"/>
    <button class="btn btn-info">
        Buscar bichos
    </button>
</form>

@foreach (Pokemon p in Model)
{
    <div class="card" style="width:400px">
        <img class="card-img-top"
             src="@p.Imagen" alt="Card image">
        <div class="card-body">
            <h4 class="card-title">@p.Nombre</h4>
            <p class="card-text">@p.CardRarity</p>
            <p class="card-text">@p.CardRarityName</p>
            <p class="card-text">@p.CardName</p>
            <p class="card-text">@p.Tipo</p>
            <p class="card-text">@p.Puntos</p>
        </div>
    </div>
}